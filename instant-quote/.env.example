# Frontend configuration — copy to .env (gitignored).
# PLACEHOLDERS ONLY — never put real values in this file.
# Local dev needs nothing here.

# Dev-server proxy target for /api. Default: http://localhost:8080
# API_PROXY=http://localhost:8080

# Canonical public origin (SEO: canonical URLs, sitemap, og:url).
# VITE_SITE_URL=https://microfactory.example
