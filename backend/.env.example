# Backend configuration — copy to .env (gitignored) or inject via Coolify env.
# PLACEHOLDERS ONLY — never put real values in this file.
# Local dev needs nothing here: the root Makefile defaults DATABASE_URL and
# the S3_* vars to the docker-compose Postgres/MinIO.

# Listen port. Default: 8080
# PORT=8080

# Postgres DSN. REQUIRED in production (the binary fails fast without it);
# local dev defaults to postgres://dev:dev@localhost:5432/instantquote.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# MakerWorld/Bambu Cloud token for /api/v1/makerworld/fetch. Optional — the
# endpoint degrades gracefully without it. Expires ~90 days. Backend-owned.
# BAMBU_CLOUD_TOKEN=

# MinIO / S3-compatible storage. Defaults match docker-compose MinIO.
# S3_ENDPOINT=localhost:9000
# S3_PUBLIC_ENDPOINT=            # browser-facing host, if it differs from S3_ENDPOINT
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=instantquote
# S3_USE_SSL=false

# Days to keep uploaded files that never reached an order. Default: 30
# FILE_RETENTION_UNORDERED_DAYS=30

# Test-only: enables the DB/S3-backed test suites (skipped when unset).
# TEST_DATABASE_URL=postgres://dev:dev@localhost:5432/instantquote
# TEST_S3_ENDPOINT=localhost:9000
